{
  "name": "yyc3-cloudpivot-intelli-matrix",
  "version": "1.0.0",
  "description": "YYC³ Family 本地闭环多端推理矩阵数据看盘系统",
  "main": "dist-electron/main.js",
  "author": "YanYuCloudCube Team <admin@0379.email>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && vite build && electron-builder",
    "build:mac": "tsc -p electron/tsconfig.json && vite build && electron-builder --mac",
    "build:win": "tsc -p electron/tsconfig.json && vite build && electron-builder --win",
    "build:linux": "tsc -p electron/tsconfig.json && vite build && electron-builder --linux",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3218 && electron .\"",
    "electron:build": "tsc -p electron/tsconfig.json && vite build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run",
    "check-headers": "node scripts/check-headers.js",
    "add-header": "node scripts/add-header.js",
    "setup-git-hooks": "bash scripts/setup-git-hooks.sh",
    "clean": "rm -rf dist dist-electron node_modules/.vite .vite"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@popperjs/core": "^2.11.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.98.0",
    "@uiw/react-codemirror": "^4.25.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.5",
    "next-themes": "^0.4.6",
    "open": "^10.0.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.0",
    "react-responsive-masonry": "^2.7.1",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "react-slick": "^0.31.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@electron/rebuild": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron": "^1.6.10",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.yyc3.cloudpivot.intelli-matrix",
    "productName": "YYC³ CloudPivot",
    "directories": {
      "output": "dist-electron",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon.icns",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMainNibFile": "MainMenu",
        "NSHighResolutionCapable": "true",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": "true"
        }
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YYC³ CloudPivot",
      "license": "LICENSE",
      "installerIcon": "public/icons/icon-512.png",
      "uninstallerIcon": "public/icons/icon-512.png",
      "installerHeader": "public/icons/installer-header.png",
      "installerHeaderIcon": "public/icons/installer-header-icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "YanYuCloudCube",
      "repo": "CloudPivot-Intelli-Matrix",
      "private": false
    }
  }
}
