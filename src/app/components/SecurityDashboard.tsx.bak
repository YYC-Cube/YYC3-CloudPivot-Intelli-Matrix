import { useState, useEffect } from "react";
import { Shield, AlertTriangle, CheckCircle, Clock, Activity, Database, Zap, TrendingUp } from "lucide-react";
import { performanceMonitor, PERFORMANCE_BUDGET } from "../lib/security/performance-monitor";
import { intrusionDetection } from "../lib/security/intrusion-detection";
import type { IntrusionAlert } from "../lib/security/intrusion-detection";

interface MetricCardProps {
  title: string;
  value: string | number;
  unit?: string;
  status: "good" | "warning" | "critical";
  icon: React.ReactNode;
}

function MetricCard({ title, value, unit, status, icon }: MetricCardProps) {
  const statusColors = {
    good: "border-[rgba(34,197,94,0.3)] bg-[rgba(34,197,94,0.08)]",
    warning: "border-[rgba(234,179,8,0.3)] bg-[rgba(234,179,8,0.08)]",
    critical: "border-[rgba(239,68,68,0.3)] bg-[rgba(239,68,68,0.08)]",
  };

  const iconColors = {
    good: "text-green-400",
    warning: "text-yellow-400",
    critical: "text-red-400",
  };

  return (
    <div className={`rounded-xl border p-4 ${statusColors[status]}`}>
      <div className="flex items-center justify-between mb-2">
        <span className="text-[rgba(0,212,255,0.5)]" style={{ fontSize: "0.7rem" }}>{title}</span>
        <div className={iconColors[status]}>{icon}</div>
      </div>
      <div className="text-[#e0f0ff] text-2xl font-bold">
        {value}
        {unit && <span className="text-sm text-[rgba(0,212,255,0.4)] ml-1">{unit}</span>}
      </div>
    </div>
  );
}

export function SecurityDashboard() {
  const [activeTab, setActiveTab] = useState<"performance" | "security">("performance");
  const [metrics, setMetrics] = useState(performanceMonitor.getMetrics());
  const [alerts, setAlerts] = useState<IntrusionAlert[]>([]);
  const [stats, setStats] = useState(intrusionDetection.getStatistics());

  useEffect(() => {
    const interval = setInterval(() => {
      setMetrics(performanceMonitor.getMetrics());
      setAlerts(intrusionDetection.getUnresolvedAlerts());
      setStats(intrusionDetection.getStatistics());
    }, 5000);

    return () => clearInterval(interval);
  }, []);

  const getMetricStatus = (value: number | undefined, budget: number | undefined): "good" | "warning" | "critical" => {
    if (!value || !budget) {return "good";}
    const ratio = value / budget;
    if (ratio < 0.8) {return "good";}
    if (ratio < 1) {return "warning";}
    return "critical";
  };

  const getSeverityColor = (severity: string) => {
    switch (severity) {
      case "critical": return "text-red-400 bg-red-400/10 border-red-400/30";
      case "high": return "text-orange-400 bg-orange-400/10 border-orange-400/30";
      case "medium": return "text-yellow-400 bg-yellow-400/10 border-yellow-400/30";
      case "low": return "text-blue-400 bg-blue-400/10 border-blue-400/30";
      default: return "text-gray-400 bg-gray-400/10 border-gray-400/30";
    }
  };

  const clearAlerts = () => {
    intrusionDetection.clearAlerts();
    setAlerts([]);
    setStats(intrusionDetection.getStatistics());
  };

  const resolveAlert = (alertId: string) => {
    intrusionDetection.resolveAlert(alertId);
    setAlerts(intrusionDetection.getUnresolvedAlerts());
    setStats(intrusionDetection.getStatistics());
  };

  return (
    <div className="space-y-4">
      <div className="flex items-center gap-2">
        <Shield className="w-5 h-5 text-[#00d4ff]" />
        <h2 className="text-[#00d4ff] text-lg font-semibold">安全与性能监控</h2>
      </div>

      <div className="flex gap-2 mb-4">
        <button
          onClick={() => setActiveTab("performance")}
          className={`px-4 py-2 rounded-lg transition-all ${
            activeTab === "performance"
              ? "bg-[rgba(0,212,255,0.2)] text-[#00d4ff] border border-[rgba(0,212,255,0.3)]"
              : "bg-[rgba(0,40,80,0.3)] text-[rgba(0,212,255,0.4)] hover:bg-[rgba(0,40,80,0.5)]"
          }`}
        >
          <span className="flex items-center gap-2">
            <Zap className="w-4 h-4" />
            性能指标
          </span>
        </button>
        <button
          onClick={() => setActiveTab("security")}
          className={`px-4 py-2 rounded-lg transition-all ${
            activeTab === "security"
              ? "bg-[rgba(0,212,255,0.2)] text-[#00d4ff] border border-[rgba(0,212,255,0.3)]"
              : "bg-[rgba(0,40,80,0.3)] text-[rgba(0,212,255,0.4)] hover:bg-[rgba(0,40,80,0.5)]"
          }`}
        >
          <span className="flex items-center gap-2">
            <Shield className="w-4 h-4" />
            安全告警
          </span>
        </button>
      </div>

      {activeTab === "performance" && (
        <div className="space-y-4">
          <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
            <MetricCard
              title="FCP (首次内容绘制)"
              value={metrics.FCP?.toFixed(0) || "-"}
              unit="ms"
              status={getMetricStatus(metrics.FCP, PERFORMANCE_BUDGET.FCP)}
              icon={<Clock className="w-5 h-5" />}
            />
            <MetricCard
              title="LCP (最大内容绘制)"
              value={metrics.LCP?.toFixed(0) || "-"}
              unit="ms"
              status={getMetricStatus(metrics.LCP, PERFORMANCE_BUDGET.LCP)}
              icon={<Activity className="w-5 h-5" />}
            />
            <MetricCard
              title="FID (首次输入延迟)"
              value={metrics.FID?.toFixed(0) || "-"}
              unit="ms"
              status={getMetricStatus(metrics.FID, PERFORMANCE_BUDGET.FID)}
              icon={<Zap className="w-5 h-5" />}
            />
            <MetricCard
              title="CLS (累积布局偏移)"
              value={metrics.CLS?.toFixed(3) || "-"}
              status={getMetricStatus(metrics.CLS, PERFORMANCE_BUDGET.CLS)}
              icon={<TrendingUp className="w-5 h-5" />}
            />
            <MetricCard
              title="TTFB (首字节时间)"
              value={metrics.TTFB?.toFixed(0) || "-"}
              unit="ms"
              status={getMetricStatus(metrics.TTFB, PERFORMANCE_BUDGET.TTFB)}
              icon={<Database className="w-5 h-5" />}
            />
            <MetricCard
              title="平均查询时长"
              value={performanceMonitor.getAverageQueryDuration().toFixed(0)}
              unit="ms"
              status="good"
              icon={<Activity className="w-5 h-5" />}
            />
          </div>

          <div className="rounded-xl bg-[rgba(8,25,55,0.6)] border border-[rgba(0,180,255,0.15)] p-4">
            <h3 className="text-[#00d4ff] mb-3" style={{ fontSize: "0.85rem" }}>性能预算目标</h3>
            <div className="space-y-2">
              <div className="flex justify-between items-center text-sm">
                <span className="text-[rgba(0,212,255,0.5)]">FCP</span>
                <span className="text-[#e0f0ff]">&lt; {PERFORMANCE_BUDGET.FCP}ms</span>
              </div>
              <div className="flex justify-between items-center text-sm">
                <span className="text-[rgba(0,212,255,0.5)]">LCP</span>
                <span className="text-[#e0f0ff]">&lt; {PERFORMANCE_BUDGET.LCP}ms</span>
              </div>
              <div className="flex justify-between items-center text-sm">
                <span className="text-[rgba(0,212,255,0.5)]">FID</span>
                <span className="text-[#e0f0ff]">&lt; {PERFORMANCE_BUDGET.FID}ms</span>
              </div>
              <div className="flex justify-between items-center text-sm">
                <span className="text-[rgba(0,212,255,0.5)]">CLS</span>
                <span className="text-[#e0f0ff]">&lt; {PERFORMANCE_BUDGET.CLS}</span>
              </div>
              <div className="flex justify-between items-center text-sm">
                <span className="text-[rgba(0,212,255,0.5)]">TTFB</span>
                <span className="text-[#e0f0ff]">&lt; {PERFORMANCE_BUDGET.TTFB}ms</span>
              </div>
            </div>
          </div>
        </div>
      )}

      {activeTab === "security" && (
        <div className="space-y-4">
          <div className="grid grid-cols-2 gap-3">
            <div className="rounded-xl bg-[rgba(8,25,55,0.6)] border border-[rgba(0,180,255,0.15)] p-4">
              <div className="flex items-center justify-between mb-2">
                <span className="text-[rgba(0,212,255,0.5)] text-sm">未解决告警</span>
                <AlertTriangle className="w-5 h-5 text-yellow-400" />
              </div>
              <div className="text-[#e0f0ff] text-2xl font-bold">{stats.unresolved}</div>
            </div>
            <div className="rounded-xl bg-[rgba(8,25,55,0.6)] border border-[rgba(0,180,255,0.15)] p-4">
              <div className="flex items-center justify-between mb-2">
                <span className="text-[rgba(0,212,255,0.5)] text-sm">已解决告警</span>
                <CheckCircle className="w-5 h-5 text-green-400" />
              </div>
              <div className="text-[#e0f0ff] text-2xl font-bold">{stats.resolved}</div>
            </div>
          </div>

          {alerts.length === 0 ? (
            <div className="rounded-xl bg-[rgba(34,197,94,0.08)] border border-[rgba(34,197,94,0.2)] p-6 text-center">
              <CheckCircle className="w-12 h-12 text-green-400 mx-auto mb-3" />
              <p className="text-[#e0f0ff]">当前没有未解决的安全告警</p>
              <p className="text-[rgba(0,212,255,0.4)] text-sm mt-2">系统运行正常</p>
            </div>
          ) : (
            <div className="space-y-3">
              <div className="flex justify-between items-center">
                <h3 className="text-[#00d4ff] text-sm">最近告警</h3>
                <button
                  onClick={clearAlerts}
                  className="text-[rgba(0,212,255,0.5)] text-sm hover:text-[#00d4ff] transition-colors"
                >
                  清除所有
                </button>
              </div>
              <div className="space-y-2 max-h-[400px] overflow-y-auto">
                {alerts.slice(0, 20).map((alert) => (
                  <div
                    key={alert.id}
                    className={`rounded-lg border p-3 ${getSeverityColor(alert.severity)}`}
                  >
                    <div className="flex items-start justify-between gap-2">
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-2 mb-1">
                          <span className="font-medium" style={{ fontSize: "0.75rem" }}>
                            {alert.type.replace(/_/g, ' ').toUpperCase()}
                          </span>
                          <span
                            className={`px-2 py-0.5 rounded text-xs ${
                              alert.severity === "critical" ? "bg-red-500/20 text-red-400" :
                              alert.severity === "high" ? "bg-orange-500/20 text-orange-400" :
                              alert.severity === "medium" ? "bg-yellow-500/20 text-yellow-400" :
                              "bg-blue-500/20 text-blue-400"
                            }`}
                          >
                            {alert.severity}
                          </span>
                        </div>
                        <p className="text-sm" style={{ fontSize: "0.7rem" }}>{alert.details}</p>
                        <p className="text-[rgba(0,212,255,0.4)] text-xs mt-1">
                          {new Date(alert.timestamp).toLocaleString('zh-CN')}
                        </p>
                      </div>
                      {!alert.resolved && (
                        <button
                          onClick={() => resolveAlert(alert.id)}
                          className="shrink-0 p-1 rounded hover:bg-black/20 transition-colors"
                          title="标记为已解决"
                        >
                          <CheckCircle className="w-4 h-4" />
                        </button>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div className="rounded-xl bg-[rgba(8,25,55,0.6)] border border-[rgba(0,180,255,0.15)] p-4">
            <h3 className="text-[#00d4ff] mb-3" style={{ fontSize: "0.85rem" }}>告警统计</h3>
            <div className="grid grid-cols-2 gap-2">
              {Object.entries(stats.byType).map(([type, count]) => (
                <div key={type} className="flex justify-between items-center text-sm">
                  <span className="text-[rgba(0,212,255,0.5)]">
                    {type.replace(/_/g, ' ').toUpperCase()}
                  </span>
                  <span className="text-[#e0f0ff]">{count}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
